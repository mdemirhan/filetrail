{
  "name": "@filetrail/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "build:icon": "bash ./scripts/build-app-icon.sh",
    "prestart": "bun run build:icon && bun run build",
    "start": "electron .",
    "start:verbose": "electron . --verbose",
    "make:mac": "bash ./scripts/make-macos-app.sh",
    "make:mac:x64": "bash ./scripts/make-macos-app.sh x64",
    "make:mac:arm64": "bash ./scripts/make-macos-app.sh arm64"
  },
  "dependencies": {
    "@filetrail/contracts": "workspace:*",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/fira-code": "latest",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lexend": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "electron": "35.0.0",
    "png2icons": "^2.0.1"
  }
}
